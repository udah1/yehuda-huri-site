{
  "name": "yehuda-huri-site",
  "version": "1.0.0",
  "description": "Yehuda Huri personal portfolio site — React + Vite marketing pages (EN/HE, RTL).",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
